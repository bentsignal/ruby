{
  "name": "@acme/mobile",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "dev": "portless run --name mobile.ruby node ../../scripts/expo-portless-bridge.mjs expo start",
    "dev:android": "portless run --name mobile.ruby node ../../scripts/expo-portless-bridge.mjs expo start --android",
    "dev:ios": "portless run --name mobile.ruby node ../../scripts/expo-portless-bridge.mjs expo start --ios",
    "android:forward": "adb reverse tcp:3000 tcp:3000",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "install:ios-sim": "xcrun simctl install booted ./Ruby.app"
  },
  "dependencies": {
    "@acme/app-config": "workspace:*",
    "@acme/convex": "workspace:*",
    "@acme/features": "workspace:*",
    "@acme/std": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/ui-mobile": "workspace:*",
    "@better-auth/expo": "catalog:",
    "@convex-dev/better-auth": "catalog:",
    "@convex-dev/react-query": "^0.1.0",
    "@expo-google-fonts/roboto": "^0.4.2",
    "@expo/ui": "~0.2.0-beta.9",
    "@legendapp/list": "^2.0.19",
    "@tailwindcss/postcss": "catalog:",
    "@tanstack/react-query": "catalog:",
    "better-auth": "catalog:",
    "convex": "catalog:",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-glass-effect": "~0.1.8",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^0.562.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-native": "catalog:react19",
    "react-native-css": "3.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.3",
    "react-native-safe-area-context": "~5.6.1",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "~0.5.1",
    "rostra": "catalog:",
    "superjson": "2.2.3",
    "tailwindcss": "catalog:",
    "uniwind": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@expo/config-plugins": "^54.0.4",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "prettier": "@acme/prettier-config"
}
