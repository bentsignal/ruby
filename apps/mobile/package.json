{
  "name": "@acme/mobile",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "dev": "portless \"$(../../scripts/portless-app-name.sh mobile.ruby)\" node ../../scripts/expo-portless-bridge.mjs expo start",
    "dev:android": "portless \"$(../../scripts/portless-app-name.sh mobile.ruby)\" node ../../scripts/expo-portless-bridge.mjs expo start --android",
    "dev:ios": "portless \"$(../../scripts/portless-app-name.sh mobile.ruby)\" node ../../scripts/expo-portless-bridge.mjs expo start --ios",
    "android:forward": "adb reverse tcp:3000 tcp:3000",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "install:ios-sim": "xcrun simctl install booted ./Ruby.app"
  },
  "dependencies": {
    "@acme/config": "workspace:*",
    "@acme/convex": "workspace:*",
    "@acme/features": "workspace:*",
    "@acme/std": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/ui-mobile": "workspace:*",
    "@better-auth/expo": "catalog:",
    "@convex-dev/better-auth": "catalog:",
    "@convex-dev/react-query": "^0.1.0",
    "@expo-google-fonts/roboto": "^0.4.2",
    "@expo/metro-runtime": "~56.0.14",
    "@expo/ui": "~56.0.16",
    "@legendapp/list": "^2.0.19",
    "@tailwindcss/postcss": "catalog:",
    "@tanstack/react-query": "catalog:",
    "better-auth": "catalog:",
    "convex": "catalog:",
    "expo": "~56.0.9",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.17",
    "expo-constants": "~56.0.17",
    "expo-dev-client": "~56.0.19",
    "expo-file-system": "~56.0.8",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image-manipulator": "~56.0.17",
    "expo-image-picker": "~56.0.16",
    "expo-linking": "~56.0.13",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^0.562.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-native": "catalog:react19",
    "react-native-css": "3.0.1",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-pager-view": "8.0.1",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "~0.8.3",
    "rostra": "catalog:",
    "superjson": "2.2.3",
    "tailwindcss": "catalog:",
    "uniwind": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "prettier": "@acme/prettier-config"
}
